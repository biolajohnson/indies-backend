FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-string
JWT_SECRET_KEY=change-this-to-another-random-string

# Local SQLite (default for dev — no setup needed)
# DATABASE_URL=sqlite:///indies_dev.db

# Postgres (for production or if you want to use Postgres locally)
# DATABASE_URL=postgresql://user:password@localhost:5432/indies

# Stripe (get these from stripe.com — use test keys for dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Platform fee percentage (default 7%)
PLATFORM_FEE_PERCENT=7.0
